{
  "name": "@responsible-ai-labs/rail-score",
  "version": "2.3.1",
  "description": "JavaScript/TypeScript SDK for RAIL Score API - Evaluate responsible AI content",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "rail-score",
    "responsible-ai",
    "ai-safety",
    "ai-ethics",
    "content-moderation",
    "compliance",
    "gdpr",
    "hipaa",
    "eu-ai-act",
    "rag-evaluation",
    "hallucination-detection",
    "guardrails",
    "llm-safety",
    "policy-engine",
    "observability",
    "typescript"
  ],
  "author": "Responsible AI Labs <support@responsibleailabs.ai>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Responsible-AI-Labs/rail-score-js.git"
  },
  "homepage": "https://responsibleailabs.ai",
  "bugs": {
    "url": "https://github.com/Responsible-AI-Labs/rail-score-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=16.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.0.0",
    "typescript": "^5.2.0"
  },
  "dependencies": {
    "node-fetch": "^3.3.2"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@anthropic-ai/sdk": ">=0.20.0",
    "@google/generative-ai": ">=0.1.0",
    "langfuse": ">=2.0.0",
    "@opentelemetry/api": ">=1.0.0",
    "@opentelemetry/sdk-node": ">=0.40.0",
    "@opentelemetry/exporter-trace-otlp-grpc": ">=0.40.0",
    "@opentelemetry/exporter-trace-otlp-http": ">=0.40.0"
  },
  "peerDependenciesMeta": {
    "openai": {
      "optional": true
    },
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "langfuse": {
      "optional": true
    },
    "@opentelemetry/api": {
      "optional": true
    },
    "@opentelemetry/sdk-node": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-grpc": {
      "optional": true
    },
    "@opentelemetry/exporter-trace-otlp-http": {
      "optional": true
    }
  }
}
